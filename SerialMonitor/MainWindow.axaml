<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:SerialMonitor.ViewModels"
        xmlns:convertors="clr-namespace:SerialMonitor.Convertors"
        xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SerialMonitor.MainWindow"
        Background="#1b1b1c"
        Title="Serial Monitor"

        x:DataType="viewModels:MainWindowViewModel">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Panel Margin="5,5">

        <Grid RowDefinitions="Auto , *,Auto">

            <WrapPanel Grid.Row="0" HorizontalAlignment="Stretch"
                       VerticalAlignment="Center">


                <Button Classes="G" Margin="2,0" Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding CanRefresh}">
                    <StackPanel Orientation="Horizontal">
                        <Svg MaxWidth="20" MaxHeight="20" Path="/Assets/reload.svg"
                             Css=".Black { fill: #00000000; stroke: #ffffff}" />
                        <TextBlock Text="Reload" Margin="2,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <ComboBox Margin="2,0"
                          ItemsSource="{Binding Ports}"
                          SelectedItem="{Binding SelectedPort}"
                          MaxWidth="500">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding ComPortName}" FontWeight="Bold" />
                                <TextBlock Text="{Binding DeviceName}" Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <ComboBox
                    Margin="2,0"
                    ItemsSource="{Binding BaudRateValues}"
                    SelectedItem="{Binding SelectedBaudRate}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Classes="G" Margin="2,0" Content="{Binding ConnectButtonText}"
                        Command="{Binding ConnectCommand}" />

            </WrapPanel>
            <Panel Grid.Row="1" Margin="0,5">
                <Grid>
                    <avaloniaEdit:TextEditor Grid.Column="0" x:Name="Editor" ShowLineNumbers="True" IsReadOnly="True"
                                             FontSize="15" />
                    <Border IsVisible="{Binding IsLogPanelVisible}">
                        <Grid ColumnDefinitions="*,1, Auto">
                            <GridSplitter Grid.Column="1" Width="1" Background="Transparent" />

                            <Grid MinWidth="300" Margin="2,0,0,0" Background="#1b1b1c" Grid.Column="2" ZIndex="10"
                                  HorizontalAlignment="Stretch">
                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding ListCommands}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="2" BorderBrush="#43454a" BorderThickness="1"
                                                        Margin="0,2">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <Button Classes="Select" Grid.Column="0"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                Click="Button_OnClickSelectMessageItem" MinWidth="150"
                                                                Content="{Binding}" />
                                                        <Button Classes="Close" Grid.Column="1"
                                                                Click="Button_OnClickSelectSendCommand">

                                                            <Svg MaxWidth="20" Path="/Assets/send.svg" />
                                                        </Button>
                                                        <Button Classes="Close" Grid.Column="2"
                                                                Click="Button_OnClickRemoveItem">

                                                            <Svg MaxWidth="20" Path="/Assets/close.svg" />
                                                        </Button>


                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>

                </Grid>

            </Panel>


            <Grid Grid.Row="2" Background="#262626" ColumnDefinitions="*,Auto,Auto">

                <TextBox x:Name="LogTextBox" Margin="2,0" Classes="Log" VerticalContentAlignment="Center"
                         Text="{Binding ReceivedData}"
                         Watermark="Data from COM port will appear here...">

                </TextBox>
                <Button Classes="G" Margin="2,0" Grid.Column="1" Click="Button_OnClickSendMessage">
                    <StackPanel Orientation="Horizontal">
                        <Svg MaxWidth="20" MaxHeight="20" Path="/Assets/send.svg" />
                        <TextBlock Text="Send" Margin="10,0" />

                    </StackPanel>
                </Button>

                <Button Classes="G" Margin="2,0" Grid.Column="2" Click="Button_OnClickShowListMessages">
                    <Svg MaxWidth="20" MaxHeight="20" Path="/Assets/box_list.svg"
                         Css=".Black { fill: #00000000; stroke: #ffffff}" />
                </Button>
            </Grid>
        </Grid>
    </Panel>


</Window>